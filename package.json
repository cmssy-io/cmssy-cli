{
  "name": "@cmssy/cli",
  "version": "1.0.0",
  "description": "CLI for wiring a Next.js app to a headless cmssy workspace",
  "type": "module",
  "bin": {
    "cmssy": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cmssy",
    "cli",
    "headless",
    "cms",
    "nextjs"
  ],
  "author": "Cmssy Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cmssy-io/cmssy-cli.git"
  },
  "homepage": "https://github.com/cmssy-io/cmssy-cli#readme",
  "bugs": {
    "url": "https://github.com/cmssy-io/cmssy-cli/issues"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
